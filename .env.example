# Copy this file to .env and fill in your values:
#   copy .env.example .env

# Required — OpenRouter API key (embeddings + LLM)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter API base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Optional — use OpenAI directly for LLM instead of OpenRouter (llm.py fallback)
# OPENAI_API_KEY=your_openai_key_here

# Optional — local vector store path (default: ./data/vectors.npz)
# VECTOR_STORE_PATH=./data/vectors.npz